table Order_details
	lineageTag: 0c5f6655-1837-429d-9970-8d2fce03ba96

	measure 'Total Sales' = sum(Order_details[Order Value])
		formatString: 0
		lineageTag: 2fefb4bc-8ae9-4175-9e9d-59a14eecb4b1

	measure 'Average Order Value' = ```
			AVERAGE(Order_details[Order Value]) 
			```
		lineageTag: b1b7a3ba-03c3-4508-be60-8a42b0a8f61e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Total Deliveries' = ```
			DISTINCTCOUNT(Order_details[Order Id]) 
			```
		formatString: 0
		lineageTag: 458d6b9c-bb78-4bf1-9518-be8c0956ecc0

	measure 'On-time Delivery %' = DIVIDE(COUNTROWS(FILTER(Delivery_details, Delivery_details[Time Taken (Min)] <= 30) ), COUNTROWS(Delivery_details) ) * 100
		lineageTag: 498318d8-d66a-4109-9fa4-e09bc845ca59

		annotation PBI_FormatHint = {"isGeneralNumber":true}

